{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "paths": {
      "@statekit/shared": ["../shared/dist/index.d.ts"],
      "@statekit/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
